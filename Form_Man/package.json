  "main": "../dist/index.js",
  "scripts": {
    "build":    "tsc",
    "copy-config": "node -e \"const fs=require('fs');fs.mkdirSync('../dist/config',{recursive:true});fs.copyFileSync('src/config/form-config.json','../dist/config/form-config.json')\"",
